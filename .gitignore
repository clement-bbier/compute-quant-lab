# Secrets — JAMAIS committés
.env
.claude/settings.local.json
**/.credentials.json

# Worktrees Claude Code (checkouts locaux, jamais committés ; cf. docs/git-workflow.md §8)
.claude/worktrees/

# Données versionnées par DVC (le contenu, pas les .dvc)
/data/raw/*
/data/interim/*
/data/processed/*
!/data/**/.gitkeep
/data/snapshots/*
!/data/snapshots/.gitkeep
# Pointeurs DVC versionnés (le .dvc est suivi, jamais le contenu)
!/data/raw/*.dvc
!/data/interim/*.dvc
!/data/processed/*.dvc
!/data/snapshots/*.dvc
!/data/**/*.dvc

# Expériences / artefacts
/experiments/mlruns/
**/results/*.png
**/results/*.parquet

# Python
__pycache__/
*.py[cod]
.venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/

# Notebooks
.ipynb_checkpoints/

# Logs du collecteur planifié (runtime, jamais committés)
infra/collectors/*.log

# Stratégies privées / à edge — JAMAIS versionnées (le repo est PUBLIC).
# Tout ce qui génère de l'argent vit ici et ne part jamais en ligne.
/private/*
!/private/README.md
!/private/.gitkeep
*.private.py
*.private.json
*.private.parquet
