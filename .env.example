# Copier en .env (JAMAIS committé) et remplir UNIQUEMENT ce que tu utilises.
# Les lignes vides sont OK : un connecteur sans token saute proprement sa source.

# ── Énergie (jambe réelle, historisée) ──
ENTSOE_API_TOKEN=

# ── Marketplaces GPU — jambe compute. 1 connecteur core/ingestion/providers/<venue>.py ──
# ── par venue. Plus on en a, plus l'indice/benchmark est robuste. Un connecteur sans   ──
# ── token saute proprement. (URL = site où ouvrir un compte gratuit puis générer la clé.) ──

# Actifs (clé en main) :
VASTAI_API_KEY=
RUNPOD_API_KEY=

# ⭐ Prime Intellect — AGGRÉGATEUR (1 clé = prix de 11+ providers via Availability API).
#    Meilleur ratio couverture/effort. → app.primeintellect.ai
PRIMEINTELLECT_API_KEY=

# Confirmés self-serve (compte gratuit → clé/token) :
# TensorDock (console.tensordock.com/api) — Developer Settings ; Bearer token :
TENSORDOCK_API_KEY=
TENSORDOCK_API_TOKEN=
# DataCrunch / Verda (console.verda.com → Keys → Cloud API Credentials) — OAuth2 (paire) :
DATACRUNCH_CLIENT_ID=
DATACRUNCH_CLIENT_SECRET=
# Hyperstack / NexGen (portal.hyperstack.cloud) — header api_key ; a une GPU Stock API :
HYPERSTACK_API_KEY=
# Lambda (cloud.lambda.ai → API keys) — Bearer ; endpoint instance-types (prix) :
LAMBDA_API_KEY=
# Genesis Cloud (developers.genesiscloud.com → Keys and Tokens) — Bearer :
GENESISCLOUD_API_KEY=
# CUDO Compute (cudocompute.com → API keys) — clé self-serve (⚠ prix parfois sur devis) :
CUDO_API_KEY=

# Non self-serve (scraping / contrat / devis — pas de token) : Paperspace, Crusoe,
# CoreWeave, hyperscalers spot (AWS/GCP/Azure), SF Compute.

# ── Indice spot compute (source canonique Silicon Data, payante) ──
SILICONDATA_API_TOKEN=
